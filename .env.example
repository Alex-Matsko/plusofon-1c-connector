# ── Plusofon API ─────────────────────────────────────────────────────────────
# Токен из ЛК: Еще → Разработчикам → API-токен
PLUSOFON_TOKEN=your_plusofon_bearer_token
# Идентификатор клиента (Client ID) из того же раздела
PLUSOFON_CLIENT_ID=your_client_id

# ── 1С:УНФ ───────────────────────────────────────────────────────────────────
# Адрес опубликованной базы 1С, например https://1c.mycompany.ru/unf
UNF_URL=http://192.168.1.100/unf
# Логин/пароль технического пользователя 1С
UNF_USER=plusofon_sync
UNF_PASSWORD=secret

# ── Поллер ───────────────────────────────────────────────────────────────────
# Интервал опроса Plusofon API в секундах (по умолчанию 30)
POLL_INTERVAL_SEC=30

# ── HTTP-сервер (порт отличен от 3000) ───────────────────────────────────────
PORT=8080
# Секрет для защиты endpoint /quickcall (1С передаёт его в заголовке X-Api-Key)
API_SECRET=change_me

# ── Хранилище состояния ───────────────────────────────────────────────────────
# Путь к файлу state.json (монтируйте Docker-volume на эту папку)
STATE_FILE=/data/state.json
