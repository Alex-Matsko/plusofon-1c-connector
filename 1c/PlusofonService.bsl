// ============================================================
// HTTP-сервис 1С:УНФ — обработчик POST /hs/plusofon/calls
//
// Вставьте этот код в обработчик метода POST шаблона URL /calls
// HTTP-сервиса «Plusofon» в расширении конфигурации УНФ.
//
// ИСПРАВЛЕНИЯ v2:
//   - ПолучитьФорму() заменена на прямое Документы.Событие.СоздатьДокумент()
//     (ПолучитьФорму недоступна в серверном контексте HTTP-сервиса)
//   - В запросе КонтактнойИнформации добавлен фильтр по КИ.Период
//     (регистр хранит историю, платформа требует дату)
// ============================================================

// ── Читаем тело запроса ───────────────────────────────────────────────────
ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();

ЧтениеJSON = Новый ЧтениеJSON;
ЧтениеJSON.УстановитьСтроку(ТелоЗапроса);
Данные = ПрочитатьJSON(ЧтениеJSON);

// Защита от пустого/некорректного тела
Если ТипЗнч(Данные) <> Тип("Соответствие") Тогда
	Ответ = Новый HTTPСервисОтвет(400);
	Ответ.УстановитьТелоИзСтроки("{\"error\": \"bad request\"}", КодировкаТекста.UTF8);
	Ответ.Заголовки["Content-Type"] = "application/json; charset=utf-8";
	Возврат Ответ;
КонецЕсли;

// ── Извлекаем поля ────────────────────────────────────────────────────────
Направление    = Данные["direction"];    // "inbound" | "outbound" | "internal" | "external"
Аккаунт        = Данные["account"];      // логин Plusofon / логин 1С сотрудника
Длительность   = ?(Данные["duration"] = Неопределено, 0, Данные["duration"]);
СсылкаЗапись   = Данные["record_url"];  // URL записи разговора или null
ВремяСтрока    = Данные["connect_time"]; // "YYYY-MM-DD HH:mm:ss"

// Определяем «внешний» номер (клиент) и признак входящего
// direction=inbound/external: number_a — клиент, number_b — сотрудник
// direction=outbound/internal: number_b — клиент, number_a — сотрудник
Если Направление = "inbound" ИЛИ Направление = "external" Тогда
	ВнешнийНомер = Данные["number_a"];
	Входящий     = Истина;
Иначе
	ВнешнийНомер = Данные["number_b"];
	Входящий     = Ложь;
КонецЕсли;

// ── 1. Нормализация номера ────────────────────────────────────────────────
Функция НормализоватьТелефон(НомерСтрока)
	Рез = "";
	Для й = 1 По СтрДлина(НомерСтрока) Цикл
		С = Сред(НомерСтрока, й, 1);
		Если Найти("0123456789", С) > 0 Тогда
			Рез = Рез + С;
		КонецЕсли;
	КонецЦикла;
	Если СтрДлина(Рез) = 11 И (Лев(Рез,1) = "7" ИЛИ Лев(Рез,1) = "8") Тогда
		Рез = Сред(Рез, 2);
	КонецЕсли;
	Возврат Рез;
КонецФункции

ВнешнийНомерНорм = НормализоватьТелефон(?(ЗначениеЗаполнено(ВнешнийНомер), ВнешнийНомер, ""));
Номер10 = ?(СтрДлина(ВнешнийНомерНорм) > 10, Прав(ВнешнийНомерНорм, 10), ВнешнийНомерНорм);

// ── 2. Разбор даты/времени начала ────────────────────────────────────────
// Формат от Plusofon: "2024-05-25 14:30:00"
Функция РазобратьДатуПлюсофон(ДатаСтрока)
	Попытка
		Части = СтрРазделить(ДатаСтрока, " ");
		Дата  = СтрРазделить(Части[0], "-");
		Время = СтрРазделить(Части[1], ":");
		Возврат Дата(Число(Дата[0]), Число(Дата[1]), Число(Дата[2]),
			         Число(Время[0]), Число(Время[1]), Число(Время[2]));
	Исключение
		Возврат ТекущаяДата();
	КонецПопытки;
КонецФункции

НачалоЗвонка    = РазобратьДатуПлюсофон(ВремяСтрока);
ОкончаниеЗвонка = НачалоЗвонка + Длительность;

// ── 3. Поиск контрагента / контактного лица по номеру ────────────────────
// ВАЖНО: РегистрСведений.КонтактнаяИнформация в УНФ ведёт историю изменений.
// Поэтому в запросе ОБЯЗАТЕЛЬНО фильтруем по максимальному периоду
// (т.е. берём актуальную запись), иначе платформа бросает исключение.
СсылкаКлиента  = Неопределено;
СсылкаКонтакта = Неопределено;

Если ЗначениеЗаполнено(Номер10) Тогда
	Попытка
		ЗапросКИ = Новый Запрос;
		ЗапросКИ.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|КИ.Объект КАК Объект
		|ИЗ РегистрСведений.КонтактнаяИнформация КАК КИ
		|ГДЕ КИ.Вид.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
		|И КИ.ПредставлениеБезФорматирования ПОДОБНО &Номер
		|И КИ.Период = &Период
		|И (ТИПЗНАЧЕНИЯ(КИ.Объект) = ТИП(Справочник.Контрагенты)
		|   ИЛИ ТИПЗНАЧЕНИЯ(КИ.Объект) = ТИП(Справочник.КонтактныеЛица))
		|УПОРЯДОЧИТЬ ПО ТИПЗНАЧЕНИЯ(КИ.Объект)";
		ЗапросКИ.УстановитьПараметр("Номер", "%" + Номер10);
		// Берём актуальные записи — период = начало текущей секунды
		ЗапросКИ.УстановитьПараметр("Период", НачалоДня(ТекущаяДата()));
		РезКИ = ЗапросКИ.Выполнить();
		Если НЕ РезКИ.Пустой() Тогда
			Найд = РезКИ.Выбрать();
			Найд.Следующий();
			Если ТипЗнч(Найд.Объект) = Тип("СправочникСсылка.КонтактныеЛица") Тогда
				СсылкаКонтакта = Найд.Объект;
				СсылкаКлиента  = Найд.Объект.Владелец;
			Иначе
				СсылкаКлиента = Найд.Объект;
			КонецЕсли;
		КонецЕсли;
	Исключение КонецПопытки;
КонецЕсли;

// ── 4. Поиск пользователя 1С по аккаунту Plusofon ────────────────────────
Автор = Неопределено;
Если ЗначениеЗаполнено(Аккаунт) Тогда
	Попытка
		ЗапросПольз = Новый Запрос;
		ЗапросПольз.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1 П.Ссылка
		|ИЗ Справочник.Пользователи КАК П
		|ГДЕ П.ИмяПользователя = &Акк И НЕ П.ПометкаУдаления";
		ЗапросПольз.УстановитьПараметр("Акк", Аккаунт);
		РезПольз = ЗапросПольз.Выполнить();
		Если НЕ РезПольз.Пустой() Тогда
			Автор = РезПольз.Выбрать().Ссылка;
		КонецЕсли;
	Исключение КонецПопытки;
КонецЕсли;

// ── 5. Формируем описание ─────────────────────────────────────────────────
Мин = Цел(Длительность / 60);
Сек = Длительность % 60;
ОписаниеДлит = "Длительность: " + Мин + " мин " + Сек + " сек";
Описание = ?(Входящий, "Plusofon — входящий звонок", "Plusofon — исходящий звонок")
	+ ". " + ОписаниеДлит;
Если ЗначениеЗаполнено(СсылкаЗапись) Тогда
	Описание = Описание + ". Запись: " + СсылкаЗапись;
КонецЕсли;

// ── 6. Создаём документ Событие напрямую (БЕЗ ПолучитьФорму) ─────────────
// ПолучитьФорму() — КЛИЕНТСКИЙ метод, недоступен в HTTP-сервисе (серверный
// контекст). Используем Документы.Событие.СоздатьДокумент() напрямую.
Попытка
	НовоеСобытие = Документы.Событие.СоздатьДокумент();

	НовоеСобытие.ТипСобытия        = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ТелефонныйЗвонок");
	НовоеСобытие.Состояние         = ПредопределенноеЗначение("Справочник.СостоянияСобытий.Завершено");
	НовоеСобытие.НачалоСобытия     = НачалоЗвонка;
	НовоеСобытие.ОкончаниеСобытия  = ОкончаниеЗвонка;
	НовоеСобытие.Содержание        = Описание;
	НовоеСобытие.Важность          = ПредопределенноеЗначение("Перечисление.ВариантыВажности.Обычная");

	Если Входящий Тогда
		НовоеСобытие.Тема = "Plusofon — входящий звонок";
		НовоеСобытие.ВходящееИсходящееСобытие = ПредопределенноеЗначение(
			"Перечисление.ВходящееИсходящееСобытие.Входящее");
	Иначе
		НовоеСобытие.Тема = "Plusofon — исходящий звонок";
		НовоеСобытие.ВходящееИсходящееСобытие = ПредопределенноеЗначение(
			"Перечисление.ВходящееИсходящееСобытие.Исходящее");
	КонецЕсли;

	Если ЗначениеЗаполнено(СсылкаКлиента) Тогда
		НовоеСобытие.Контрагент = СсылкаКлиента;
	КонецЕсли;

	Если ЗначениеЗаполнено(Автор) Тогда
		НовоеСобытие.Автор = Автор;
	КонецЕсли;

	// Табличная часть контактов
	СтрКонтакт = НовоеСобытие.Контакты.Добавить();
	СтрКонтакт.КакСвязаться = ВнешнийНомерНорм;
	Если ЗначениеЗаполнено(СсылкаКонтакта) Тогда
		СтрКонтакт.Контакт = СсылкаКонтакта;
	ИначеЕсли ЗначениеЗаполнено(СсылкаКлиента) Тогда
		СтрКонтакт.Контакт = СсылкаКлиента;
	КонецЕсли;

	НовоеСобытие.Записать(РежимЗаписиДокумента.Запись);

	СсылкаЗвонка = НовоеСобытие.Ссылка;
Исключение
	Ответ = Новый HTTPСервисОтвет(500);
	Ответ.УстановитьТелоИзСтроки(
		"{\"error\": \"" + СтрЗаменить(ОписаниеОшибки(), "\"", "'") + "\"}",
		КодировкаТекста.UTF8);
	Ответ.Заголовки["Content-Type"] = "application/json; charset=utf-8";
	Возврат Ответ;
КонецПопытки;

// ── 7. Возвращаем ответ ───────────────────────────────────────────────────
Ответ = Новый HTTPСервисОтвет(200);
Ответ.УстановитьТелоИзСтроки(
	"{\"ok\": true, \"event_ref\": \"" + XMLСтрока(СсылкаЗвонка) + "\"}",
	КодировкаТекста.UTF8
);
Ответ.Заголовки["Content-Type"] = "application/json; charset=utf-8";
Возврат Ответ;
