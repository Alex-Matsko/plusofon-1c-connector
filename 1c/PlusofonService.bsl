// ============================================================
// HTTP-сервис 1С:УНФ — обработчик POST /hs/plusofon/calls
// Вставьте этот код в обработчик метода POST шаблона URL /calls
// ============================================================

// Читаем тело запроса
ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();

ЧтениеJSON = Новый ЧтениеJSON;
ЧтениеJSON.УстановитьСтроку(ТелоЗапроса);
Данные = ПрочитатьJSON(ЧтениеJSON);

// Обязательные поля
ВнешнийНомер  = ?(ДанныеJSON["direction"] = "external", ДанныеJSON["number_a"], ДанныеJSON["number_b"]);
ВнутрНомер    = ДанныеJSON["account"];
ДатаЗвонка    = ЗначениеИзСтрокиJSON(ДанныеJSON["connect_time"]); // YYYY-MM-DD HH:mm:ss
Длительность  = ?(ДанныеJSON["duration"] = Неопределено, 0, ДанныеJSON["duration"]);
СсылкаЗапись  = ДанныеJSON["record_url"];
Направление   = ДанныеJSON["direction"];

// ── 1. Нормализация номера ────────────────────────────────────────────────
Функция НормализоватьТелефон(НомерСтрока)
    Цифры = СтрЗаменить(НомерСтрока, "+", "");
    Цифры = СтрЗаменить(Цифры, "-", "");
    Цифры = СтрЗаменить(Цифры, " ", "");
    Цифры = СтрЗаменить(Цифры, "(", "");
    Цифры = СтрЗаменить(Цифры, ")", "");
    Если СтрДлина(Цифры) = 11 И Лев(Цифры, 1) = "8" Тогда
        Цифры = "7" + Сред(Цифры, 2);
    КонецЕсли;
    Возврат Цифры;
КонецФункции

ВнешнийНомерНорм = НормализоватьТелефон(ВнешнийНомер);

// ── 2. Поиск клиента/лида по номеру ──────────────────────────────────────
// Сначала ищем среди Контактных лиц и Контрагентов
ЗапросКлиент = Новый Запрос;
ЗапросКлиент.Текст = 
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |    КонтактнаяИнформация.Ссылка КАК Ссылка,
    |    ТИПЗНАЧЕНИЯ(КонтактнаяИнформация.Ссылка) КАК ТипСсылки
    |ИЗ
    |    РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
    |ГДЕ
    |    КонтактнаяИнформация.Вид.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
    |    И ЗАМЕНИТЬ(ЗАМЕНИТЬ(ЗАМЕНИТЬ(ЗАМЕНИТЬ(ЗАМЕНИТЬ(
    |        КонтактнаяИнформация.НомерТелефона, '-', ''), ' ', ''), '(', ''), ')', ''), '+', '')
    |        ПОДОБНО &Номер";
ЗапросКлиент.УстановитьПараметр("Номер", "%" + Прав(ВнешнийНомерНорм, 10));
РезультатКлиент = ЗапросКлиент.Выполнить();

СсылкаКлиента = Неопределено;
Если НЕ РезультатКлиент.Пустой() Тогда
    СсылкаКлиента = РезультатКлиент.Выгрузить()[0].Ссылка;
КонецЕсли;

// ── 3. Создаём Лида, если клиент не найден ────────────────────────────────
Если СсылкаКлиента = Неопределено Тогда
    НовыйЛид = Справочники.Лиды.СоздатьЭлемент();
    НовыйЛид.Наименование = "Звонок с номера " + ВнешнийНомерНорм;
    НовыйЛид.ТелефонКонтакта = ВнешнийНомерНорм; // реквизит УНФ
    НовыйЛид.Источник = Перечисления.ИсточникиЛидов.ВходящийЗвонок;
    НовыйЛид.Записать();
    СсылкаКлиента = НовыйЛид.Ссылка;
КонецЕсли;

// ── 4. Ищем ответственного по account (Plusofon login = логин 1С или доп. реквизит) ──
Ответственный = Неопределено;
Если ЗначениеЗаполнено(ВнутрНомер) Тогда
    ЗапросСотр = Новый Запрос;
    ЗапросСотр.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |    Пользователи.Ссылка
        |ИЗ
        |    Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |    Пользователи.ИмяПользователя = &Аккаунт
        |    И НЕ Пользователи.ПометкаУдаления";
    ЗапросСотр.УстановитьПараметр("Аккаунт", ВнутрНомер);
    РезСотр = ЗапросСотр.Выполнить();
    Если НЕ РезСотр.Пустой() Тогда
        Ответственный = РезСотр.Выгрузить()[0].Ссылка;
    КонецЕсли;
КонецЕсли;

// ── 5. Создаём документ Взаимодействие (Звонок) ─────────────────────────
НовыйЗвонок = Документы.ВзаимодействиеТелефонныйЗвонок.СоздатьДокумент();
НовыйЗвонок.Дата             = ТекущаяДата(); // дата регистрации
НовыйЗвонок.ВремяЗвонка      = ДатаЗвонка;
НовыйЗвонок.Длительность     = Длительность;

// Направление: адаптируйте к вашим значениям перечисления
Если Направление = "external" ИЛИ Направление = "inbound" Тогда
    НовыйЗвонок.НаправлениеЗвонка = Перечисления.НаправленияЗвонков.Входящий;
Иначе
    НовыйЗвонок.НаправлениеЗвонка = Перечисления.НаправленияЗвонков.Исходящий;
КонецЕсли;

НовыйЗвонок.АбонентскийНомер = ВнешнийНомерНорм;
НовыйЗвонок.Контакт          = СсылкаКлиента;
Если ЗначениеЗаполнено(Ответственный) Тогда
    НовыйЗвонок.Ответственный = Ответственный;
КонецЕсли;

// Ссылка на запись
Если ЗначениеЗаполнено(СсылкаЗапись) Тогда
    НовыйЗвонок.КомментарийЗвонка = "Запись: " + СсылкаЗапись;
    // Или в отдельный строковый реквизит, если добавили его в конфигурацию:
    // НовыйЗвонок.ПлюсофонЗапись = СсылкаЗапись;
КонецЕсли;

НовыйЗвонок.Записать(РежимЗаписиДокумента.Запись);

// ── 6. Формируем ответ ────────────────────────────────────────────────────
Ответ = Новый HTTPСервисОтвет(200);
Ответ.УстановитьТелоИзСтроки(
    "{\"ok\": true, \"interaction_id\": \"" + XMLСтрока(НовыйЗвонок.Ссылка) + "\"}",
    КодировкаТекста.UTF8
);
Ответ.Заголовки["Content-Type"] = "application/json; charset=utf-8";
Возврат Ответ;
